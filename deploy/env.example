# /opt/mongodb-assistant/shared/.env
# Copy this file to the shared directory and edit with your values.
# See .env.example in the project root for all available options.

# ─── MongoDB ─────────────────────────────────────────────────────
MONGODB_URI=mongodb://anomaly_app:CHANGE_ME@localhost:27017/anomaly_detection?authSource=anomaly_detection
MONGODB_DATABASE=anomaly_detection
MONGODB_ENABLED=true

# ─── Storage ─────────────────────────────────────────────────────
STORAGE_PATH=/opt/mongodb-assistant/shared/storage
AUTO_SAVE_ENABLED=true
AUTO_SAVE_FORMAT=json

# ─── Web UI ──────────────────────────────────────────────────────
WEB_HOST=0.0.0.0
WEB_PORT=8000
API_KEY=CHANGE_ME_TO_RANDOM_SECRET
CORS_ORIGINS=

# ─── LLM ─────────────────────────────────────────────────────────
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ─── OpenSearch ──────────────────────────────────────────────────
OPENSEARCH_URL=https://localhost:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASS=
OPENSEARCH_VERIFY_SSL=true
OPENSEARCH_TENANT=default

# ─── Hostname Handling ──────────────────────────────────────────
MONGODB_FQDN_SUFFIX=.local
HOSTNAME_STRIP_SUFFIXES=.local,.internal,.example.com

# ─── General ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=production
