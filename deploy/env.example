# /opt/mongodb-assistant/shared/.env
# Bu dosyayı shared dizine kopyalayıp düzenleyin.

# ─── MongoDB ─────────────────────────────────────────────────────
MONGODB_URI=mongodb://anomaly_app:SIFRE@localhost:27017/anomaly_detection?authSource=anomaly_detection
MONGODB_DATABASE=anomaly_detection
MONGODB_ENABLED=true

# ─── Storage ─────────────────────────────────────────────────────
# ABSOLUTE path kullanın! Relative path systemd'de sorun yaratır.
STORAGE_PATH=/opt/mongodb-assistant/shared/storage
AUTO_SAVE_ENABLED=true
AUTO_SAVE_FORMAT=json

# ─── Web UI ──────────────────────────────────────────────────────
WEB_HOST=0.0.0.0
WEB_PORT=8000
API_KEY=PRODUCTION-KEY-DEGISTIRIN
CORS_ORIGINS=

# ─── LLM ─────────────────────────────────────────────────────────
LLM_PROVIDER=lcwgpt
LCWGPT_API_KEY=
LCWGPT_ENDPOINT=https://lcwgpt-test.lcwaikiki.com/api/service/message
LCWGPT_INSTITUTION_ID=analitikverimüdürlügü
LCWGPT_MODEL=sonnet3.5

# ─── OpenSearch ──────────────────────────────────────────────────
OPENSEARCH_URL=https://opslog.lcwaikiki.com
OPENSEARCH_USER=
OPENSEARCH_PASS=
OPENSEARCH_VERIFY_SSL=true

# ─── Genel ───────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=production
