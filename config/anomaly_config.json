      "production": {
        "description": "Production Environment - LC Waikiki",
        "data_sources": {
          "file": {
            "enabled": false,
            "path": "/var/log/mongodb/mongod.log",
            "format": "text",
            "encoding": "utf-8",
            "buffer_size": 16384
          },
          "opensearch": {
            "enabled": true,
            "host": "opslog.lcwaikiki.com",
            "port": 443,
            "protocol": "https",
            "index_pattern": "db-mongodb-*",
            "verify_ssl": true,
            "auth": {
              "username": "",
              "password": ""
            },
            "query": {
              "size": 10000,
              "scroll": "5m",
              "time_range": {
                "field": "@timestamp",
                "gte": "now-1h"
              }
            },
            "alternate_hosts": [
              "https://10.29.21.30:443",
              "https://hqopnsrcmstr01.lcwaikiki.local:9200",
              "https://hqopnsrcmstr02.lcwaikiki.local:9200",
