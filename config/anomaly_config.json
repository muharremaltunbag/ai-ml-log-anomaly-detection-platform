            ]
          },
          "filebeat": {
            "enabled": false,
            "config_path": "/etc/filebeat/filebeat.yml",
            "output": {
              "logstash": {
                "hosts": ["10.29.21.32:5044"]
              }
            }
          },
          "upload": {
            "enabled": true,
            "temp_dir": "/tmp/anomaly_logs/",
            "max_size_mb": 500,
            "allowed_formats": ["log", "txt", "json"]
          },
          "mongodb_direct": {
            "enabled": true,
            "default_connection": "mongodb://lcw_prod_user:lcw_prod_pass@10.29.21.32:27017/chatbot_prod?authSource=admin",
            "default_database": "local",
            "default_collection": "startup_log",
            "query_limit": 50000
          },
          "test_servers": {
            "enabled": false,
            "config_path": "config/monitoring_servers.json",
            "servers": ["mongodb-prod1", "mongodb-prod2", "mongodb-prod3"],
            "default_log_path": "/var/log/mongodb/mongod.log"
          }
        }
      }
    },
    "anomaly_detection": {
      "model": {
        "type": "IsolationForest",
        "parameters": {
          "contamination": 0.05,
          "n_estimators": 300,
          "max_samples": 512,
          "max_features": 0.9,
          "bootstrap": true,
          "random_state": 42,
          "n_jobs": -1
        }
      },
      "features": {
        "enabled_features": [
          "severity_W",
          "component_encoded", 
          "is_rare_component",
          "is_rare_combo",
          "has_error_key",
          "is_auth_failure",
          "is_drop_operation",
          "is_aggregate_operation",
          "is_bulk_operation",
          "is_aborted_transaction",
          "is_rare_message",
          "extreme_burst_flag",
          "burst_density",
          "component_changed",
          "hour_of_day",
          "is_weekend",
          "attr_key_count",
          "has_many_attrs",
          "is_collscan",
          "is_index_build",
          "is_slow_query",
          "is_high_doc_scan",
          "is_shutdown",
          "is_assertion",
          "is_fatal",
          "is_error",
          "is_replication_issue",
          "is_out_of_memory",
          "is_restart",
          "is_memory_limit",
          "query_duration_ms",
          "docs_examined_count",
          "keys_examined_count",
          "performance_score",
          "is_wiredtiger_recovery",
          "is_wiredtiger_checkpoint",
          "is_wiredtiger_event",
          "is_storage_event",
          "is_async_io_event",
          "is_index_event",
          "is_recovery_event",
          "is_unknown_component",
          "is_network_component",
          "is_security_component",
          "is_replication_component",
          "is_storage_component",
          "is_control_component",
          "component_criticality_score",
          "txn_time_active_micros",
          "txn_time_inactive_micros",
          "txn_wait_ratio"
        ],
        "filters": {
          "exclude_auth_success": true,
          "exclude_reauthenticate": true,
          "exclude_normal_replication": true,
          "rare_threshold": 100,
          "burst_threshold_ms": 100
        },
        "performance_thresholds": {
          "slow_query_ms": 1000,
          "high_doc_scan": 10000,
          "critical_collscan_count": 10,
          "max_index_builds": 5,
          "performance_score_threshold": 50000
        }
      },
      "output": {
        "save_model": true,
        "model_path": "models/isolation_forest.pkl",
        "export_anomalies": true,
        "anomaly_path": "output/anomalies_{timestamp}.csv",
        "notification": {
          "enabled": false,
          "webhook_url": "",
          "email": ""
        }
      },
      "ensemble": {
        "enabled": true,
        "rule_weight": 1.0,
        "combine_method": "override",
        "log_rule_hits": true,
        "rules": {
          "system_failure": {
            "enabled": true,
            "description": "Critical system failures (OOM, Fatal, Shutdown)"
          },
          "memory_crisis": {
            "enabled": true,
            "description": "Memory-related critical issues"
          },
          "performance_critical": {
            "enabled": true,
            "description": "COLLSCAN with high document count"
          },
          "error_burst": {
            "enabled": true,
            "description": "Multiple errors in short timeframe"
          },
          "security_alert": {
            "enabled": true,
            "description": "DROP operations and security issues"
          },
          "post_restart_errors": {
            "enabled": true,
            "description": "Errors after system restart"
          }
        }
      },
      "online_learning": {
        "enabled": true,
        "max_buffer_samples": 100000,
        "history_retention": "full",
        "max_history_size": null,
        "update_frequency": 1000,
        "weight_decay": 0.95,
        "buffer_management": {
          "warn_size_mb": 1000,
          "max_size_mb": 10000,
          "compression_enabled": false
        },
        "logging": {
          "log_buffer_stats": true,
          "log_incremental_updates": true
        }
      }
    },
    "processing": {
      "batch_size": 10000,
      "max_workers": 4,
      "memory_limit_gb": 8,
      "cache_enabled": true,
      "cache_path": "cache/anomaly_cache"
    },
    "logging": {
      "level": "INFO",
      "file": "logs/anomaly_detection.log",
      "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
    },
    "monitoring": {
      "performance_tracking": true,
      "metrics_export": false,
      "metrics_path": "metrics/anomaly_metrics.json"
    }
  }