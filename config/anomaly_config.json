      "production": {
        "description": "Production Environment - LC Waikiki",
        "data_sources": {
          "file": {
            "enabled": false,
            "path": "/var/log/mongodb/mongod.log",
            "format": "text",
            "encoding": "utf-8",
            "buffer_size": 16384
          },
          "opensearch": {
            "enabled": true,
            "host": "opslog.lcwaikiki.com",
            "port": 443,
            "protocol": "https",
            "index_pattern": "db-mongodb-*",
            "verify_ssl": true,
            "auth": {
              "username": "",
              "password": ""
            },
            "query": {
              "size": 10000,
              "scroll": "5m",
              "time_range": {
                "field": "@timestamp",
                "gte": "now-1h"
              }
            },
            "alternate_hosts": [
              "https://10.29.21.30:443",
              "https://hqopnsrcmstr01.lcwaikiki.local:9200",
              "https://hqopnsrcmstr02.lcwaikiki.local:9200",
              "https://hqopnsrcmstr03.lcwaikiki.local:9200"
            ]
          },
          "filebeat": {
            "enabled": false,
            "config_path": "/etc/filebeat/filebeat.yml",
            "output": {
              "logstash": {
                "hosts": ["10.29.21.32:5044"]
              }
            }
          },
          "upload": {
            "enabled": true,
            "temp_dir": "/tmp/anomaly_logs/",
            "max_size_mb": 500,
            "allowed_formats": ["log", "txt", "json"]
          },
          "mongodb_direct": {
            "enabled": true,
            "default_connection": "mongodb://lcw_prod_user:lcw_prod_pass@10.29.21.32:27017/chatbot_prod?authSource=admin",
            "default_database": "local",
            "default_collection": "startup_log",
            "query_limit": 50000
          },
          "test_servers": {
            "enabled": false,
            "config_path": "config/monitoring_servers.json",
            "servers": ["mongodb-prod1", "mongodb-prod2", "mongodb-prod3"],
            "default_log_path": "/var/log/mongodb/mongod.log"
          }
        }
      }
    },
    "anomaly_detection": {
      "model": {
        "type": "IsolationForest",
        "parameters": {
          "contamination": 0.03,
          "n_estimators": 300,
          "max_samples": 512,
          "max_features": 0.9,
          "bootstrap": true,
          "random_state": 42,
          "n_jobs": -1
        }
      },
      "features": {
        "enabled_features": [
          "severity_W",
          "component_encoded",
          "is_rare_component",
          "is_rare_combo",
          "has_error_key",
          "is_auth_failure",
          "is_drop_operation",
          "is_rare_message",
          "extreme_burst_flag",
          "burst_density",
          "component_changed",
          "hour_of_day",
          "is_weekend",
          "attr_key_count",
          "has_many_attrs"
        ],
        "filters": {
          "exclude_auth_success": true,
          "exclude_reauthenticate": true,
          "rare_threshold": 100,
          "burst_threshold_ms": 100
        }
      },
      "output": {
        "save_model": true,
        "model_path": "models/isolation_forest.pkl",
        "export_anomalies": true,
        "anomaly_path": "output/anomalies_{timestamp}.csv",
        "notification": {
          "enabled": false,
          "webhook_url": "",
          "email": ""
        }
      }
    },
    "processing": {
      "batch_size": 10000,
      "max_workers": 4,
      "memory_limit_gb": 8,
      "cache_enabled": true,
      "cache_path": "cache/anomaly_cache"
    },
    "logging": {
      "level": "INFO",
      "file": "logs/anomaly_detection.log",
      "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
    },
    "monitoring": {
      "performance_tracking": true,
      "metrics_export": false,
      "metrics_path": "metrics/anomaly_metrics.json"
    }
  }