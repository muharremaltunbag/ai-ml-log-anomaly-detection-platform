# ─── MongoDB ─────────────────────────────────────────────────────
MONGODB_URI=mongodb://anomaly_app:CHANGE_ME@localhost:27017/anomaly_detection?authSource=anomaly_detection
MONGODB_DATABASE=anomaly_detection

# ─── Storage Manager ─────────────────────────────────────────────
MONGODB_ENABLED=true
STORAGE_PATH=./data/storage
AUTO_SAVE_ENABLED=true
AUTO_SAVE_FORMAT=json
AUTO_SAVE_THRESHOLD=10
RETENTION_DAYS=90

# Storage Limits
MAX_FILE_SIZE_MB=100
MAX_TOTAL_SIZE_GB=10
ANOMALY_RETENTION_DAYS=90
MODEL_VERSIONS_COUNT=10

# ─── OpenSearch ──────────────────────────────────────────────────
OPENSEARCH_URL=https://localhost:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASS=CHANGE_ME
OPENSEARCH_VERIFY_SSL=true

# ─── LLM Provider ───────────────────────────────────────────────
# Options: openai, lcwgpt (corporate LLM), or leave empty to disable
LLM_PROVIDER=openai

# OpenAI (if LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Corporate LLM (if LLM_PROVIDER=lcwgpt)
LCWGPT_API_KEY=
LCWGPT_ENDPOINT=https://your-llm-endpoint.example.com/api/service/message
LCWGPT_INSTITUTION_ID=your-institution-id
LCWGPT_MODEL=sonnet3.5

# ─── Web UI ──────────────────────────────────────────────────────
WEB_HOST=127.0.0.1
WEB_PORT=8000
API_KEY=CHANGE_ME_TO_RANDOM_SECRET
CORS_ORIGINS=

# ─── General ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development
MAX_QUERY_LIMIT=100
QUERY_TIMEOUT=30

# ─── Linux Monitoring ────────────────────────────────────────────
MONITORING_ENV=test
MONITORING_CONFIG_PATH=config/monitoring_servers.json
MONITORING_DEFAULT_TIMEOUT=10
MONITORING_SSH_KEY_BASE_PATH=
