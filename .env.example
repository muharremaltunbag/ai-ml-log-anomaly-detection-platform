# ─── MongoDB ─────────────────────────────────────────────────────
MONGODB_URI=mongodb://anomaly_app:CHANGE_ME@localhost:27017/anomaly_detection?authSource=anomaly_detection
MONGODB_DATABASE=anomaly_detection

# ─── Storage Manager ─────────────────────────────────────────────
MONGODB_ENABLED=true
STORAGE_PATH=./data/storage
AUTO_SAVE_ENABLED=true
AUTO_SAVE_FORMAT=json
AUTO_SAVE_THRESHOLD=10
RETENTION_DAYS=90

# Storage Limits
MAX_FILE_SIZE_MB=100
MAX_TOTAL_SIZE_GB=10
ANOMALY_RETENTION_DAYS=90
MODEL_VERSIONS_COUNT=10

# ─── OpenSearch ──────────────────────────────────────────────────
OPENSEARCH_URL=https://localhost:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASS=CHANGE_ME
OPENSEARCH_VERIFY_SSL=true
# OpenSearch tenant (multi-tenant setups). Leave as 'default' for single-tenant.
OPENSEARCH_TENANT=default

# ─── LLM Provider ───────────────────────────────────────────────
# Options: openai, custom (corporate LLM), or leave empty to disable
LLM_PROVIDER=openai

# OpenAI (if LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Custom Corporate LLM (if LLM_PROVIDER=custom)
CUSTOM_LLM_API_KEY=
CUSTOM_LLM_ENDPOINT=https://your-llm-endpoint.example.com/api/service/message
CUSTOM_LLM_INSTITUTION_ID=your-institution-id
CUSTOM_LLM_MODEL=sonnet3.5

# ─── Web UI ──────────────────────────────────────────────────────
WEB_HOST=127.0.0.1
WEB_PORT=8000
API_KEY=CHANGE_ME_TO_RANDOM_SECRET
CORS_ORIGINS=

# ─── General ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development
MAX_QUERY_LIMIT=100
QUERY_TIMEOUT=30

# ─── Hostname Handling ────────────────────────────────────────────
# FQDN suffix appended to short hostnames (e.g. ".example.local")
MONGODB_FQDN_SUFFIX=.local
# Comma-separated suffixes stripped during hostname normalization
HOSTNAME_STRIP_SUFFIXES=.local,.internal,.example.com

# ─── Linux Monitoring ────────────────────────────────────────────
MONITORING_ENV=test
MONITORING_CONFIG_PATH=config/monitoring_servers.json
MONITORING_DEFAULT_TIMEOUT=10
MONITORING_SSH_KEY_BASE_PATH=
